{
  "manifest_version": 3,
  "name": "Clio satellite",
  "version": "2.3",
  "description": "Enhances Creatio CRM with profile-based quick login, admin shortcuts, and environment management for self-hosted instances.",
  "permissions": ["scripting", "activeTab", "storage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*shell/", "*://*/*Shell/", "*://*/*SHELL/", "*://*/*sHELL/"],
      "exclude_matches": ["*://*.work.creatio.com/*"],
      "css": ["styles/shell.css", "menu-item.css"],
      "js": ["content.js"]
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://*.work.creatio.com/*", "*://*/*shell/", "*://*/*Shell/", "*://*/*SHELL/", "*://*/*sHELL/"],
      "css": ["styles/login.css", "menu-item.css"],
      "js": ["login/login-events.js", "login/login.js", "content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["scripts/*", "icon48.png", "icon128.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}